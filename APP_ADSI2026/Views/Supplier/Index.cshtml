@model IEnumerable<MVC.Data.Models.Supplier>


@{
}

<!--Esto es un modal -->
<div class="row">
    <div class="col-md-8">
        <h1>listado de  Provedores</h1>
    </div>
    <div class=" col-md-4  text-end">
        <button type="button" class="btn btn-primary" onclick="openModal(false)">
            <!--con este onclick que es false, le dicimos que mientras no sea editar ejecute el modal normal -->
            <!--Esto es un icono -->
            <i class="fa-solid fa-circle-plus"></i>
            Crear Provedor
        </button>
    </div>
</div>


<!--Esto es un datatable -->
<div class="row">
    <div class="col-md-12">
        <table class="table" id="tbSupplier">
            <thead class="thead-dark">
                <tr>
                    <th>Id</th>
                    <th>Pais</th>
                    <th>Empresa</th>
                    <th>Responsable</th>
                    <th>telefono</th>
                    <th>Dirrecion</th>
                    <th>Ciudad</th>
                    <th>Acciones</th>

                </tr>
            </thead>
            <tbody>
            </tbody>

        </table>

    </div>

</div>




<div class="modal fade" id="modalSupplier" tabindex="-1" data-bs-backdrop="static" data-bs-Keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="titleModal">Crear Cliente</h5>
                <button type="button" class="btn-close" onclick="clearFormSupplier()"></button>
            </div>
            <div class="modal-body">


                <!--Esto es la etiqueta para crear un formulario -->
                <form>
                    <section class="row">
                      
                        <div class="col-md-6">
                            <label class="col-form-label">Pais</label>
                            <input type="text" class="form-control" id="txtCountry" placeholder="Digita el pais" />
                        </div>
                        <div class="col-md-6">
                            <label class="col-form-label">Empresa</label>
                            <input type="text" class="form-control" id="txtCompany" placeholder="Digita la Empresa" />
                        </div>
                    </section>

                    <section class="row">
                        <div class="col-md-6">
                            <label class="col-form-label">Respnsable</label>
                            <input type="text" class="form-control" id="txtContactName" placeholder="Digita el Responsable" />
                        </div>
                        <div class="col-md-6">
                            <label class="col-form-label">Telefono</label>
                            <input type="text" class="form-control" id="txtPhone" placeholder="Digita el Telefono" />
                        </div>
                    </section>
                    <section class="row">
                        <div class="col-md-6">
                            <label class="col-form-label">Dirrecion</label>
                            <input type="text" class="form-control" id="txtAddress" placeholder="Digita la Dirreccion" />
                        </div>
                        <div class="col-md-6">
                            <label class="col-form-label">Ciudad</label>
                            <input type="text" class="form-control" id="txtCity" placeholder="Digita la ciudad" />
                        </div>
                    </section>
                </form>




            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger" onclick="clearFormSupplier()">Cerrar</button>
                <button id="btnModalSave" type="button" class="btn btn-outline-success" onclick="onSaveSupplier()">Crear</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script type="text/javascript">

        //variable global de idSupplier
        var idSupplier= 0;
        //esta lista es para obtener la infromacion del Supplier que estoy consultando
        var listSupplier=[];


        $(document).ready(function () {
            console.log("Hola clase")
            getAllSupplier();

        });

        // Función para traer la información
        function getAllSupplier() {
            $.ajax({
                url: '@Url.Action("GetAllSupplier", "Supplier")', // cambia esta ruta por la real
                method: 'GET', //aqui le indicamos el metodo http que vamos  a usar
                dataType:'json', //aqui le decimos el tipo de dato que queremos enviar o traer casi simepr ees json
                success: function (result) {
                    listSupplier=result;
                    console.log(listSupplier)
                    //aqui le estoy diciendo que pase la informacion a la tabla
                    loadTable(listSupplier);
                },
                error: function (error) {
                    console.error(error);
                }
            });
        }

        // Configuración del DataTable: función para mostrar la información
        function loadTable(data) {
            $('#tbSupplier').DataTable({
                data: data,
                // destruye la tabla anterior y la vuelve a cargar
                destroy: true,
                // permite que la tabla se adapte al tamaño de la pantalla
                responsive: true, //esta linea hace que la tabla sea responsive y se adapta a todo tipo de pantallas

                columns: [
                    { data: 'supplierId' },
                    { data: 'country' },
                    { data: 'companyName' },
                    { data: 'contactName' },
                    { data: 'phone' },
                    {data: 'address'},
                    {data: 'city'},

                    {
                    // Columna de acciones:
                    // Se genera una columna especial dentro de la tabla que añade botones de
                    // "Editar" y "Eliminar" para cada cliente mostrado.
                    // Estos botones se crean dinámicamente tomando el id del cliente de la fila actual,
                    // de modo que cada registro tenga sus propias acciones asociadas.
                    // Esto permite gestionar la información directamente desde la tabla sin necesidad
                    // de escribir los botones manualmente en el HTML.
                        data: null,
                        render:function(data)
                        {
                            //Codigo para colocar los botones de editar y eliminar
                            const id = data.supplierId;
                            return `
                                     <button  class="btn btn-warning" onclick = "editSupplier(`+ id + `)" >
                                     <i class="fas fa-edit" > </i> Editar
                                     </button >
                                     <button class="btn btn-danger" onclick = "deleteSupplier(`+ id + `)" >
                                     <i class="far fa-trash-alt" > </i> Eliminar
                                     </button >

                                   `
                        }
                    }
                ]
            });
        }

        //Esta uncion se utiliza para decirle al navegador que vamos a eliminar un registro
        function deleteSupplier(supplierId){
            alertDelete().then((result)=>{
                if(result.isConfirmed)
                {
                    //aqui estamos llamando la funcion de confirmacion para realizar los cambios en la base de datos
                    confirmDeleteSupplier(supplierId)
                    console.log('se elimino', supplierId )
                }else
                {
                    console.log('No eliminar', supplierId )
                }
            });
        }
        //con esta funcion confrimamos la eliminacion enviamos la peticion a la base de datos y guardamos los cambios
        function confirmDeleteSupplier(id) {
            $.ajax({
                url: '@Url.Action("DeleteSupplier", "Supplier")', // cambia esta ruta por la real
                method: 'DELETE',
                //data son los parametros que vamos a enviar
                data:{
                    'supplierId' : id
                },
                DataTable: 'json',
                success: function(result){
                    console.log(result);
                    toastMessage('sucess', 'Registro eliminado exitosamente')
                    getAllSupplier();

                },
                error: function (error) {
                    console.error(error);
                    alertError('Ha ocurrido un error, por favor vuelve a intentarlo');
                }
            });
        }

        //funcion para abrir y editar el modal en base al button de ediar registro
        function openModal(isEdit){
            if(isEdit) //con este if  le dicimos que mientras sea editar ejecute el modal con los cambios a editar
            {
                $('#titleModal').html('Editar Provedores') //esta linea de codigo modifica el htm desde js
                $('#btnModalSave').html('Editar') //esta linea de codigo edita un boton ddel html y lo cambia por editar
            }
            else
            {
                $('#titleModal').html('Crear Cliente') //esta linea de codigo modifica el htm desde js busco un id y cambia lo que hay en el id por lo que le digamos
                $('#btnModalSave').html('Crear') //esta linea de codigo edita un boton del html y lo cambia por crear
            }
             $('#modalSupplier').modal('show');
        }

        //funcion para eliminar el formulario
        function clearFormSupplier(){
             $('#txtCountry').val('');
             $('#txtCompany').val('');
             $('#txtContactName').val('');
             $('#txtPhone').val('');
             $('#txtAddress').val('');
             $('#txtCity').val('');

             $('#modalSupplier').modal('hide'); //esta linea de codigo cierra el modal con hide
             idSupplier = '';
             $('#txtId').attr('disabled', false);//cuando es false se hablita cuando es true se ihnabilita
        }



        //capturar la informacion
        function onSaveSupplier(){
            if(validateForm())
            {
                //val() se usa para decirle que los capture
                const country = $('#txtCountry').val();
                const company = $('#txtCompany').val();
                const contactName = $('#txtContactName').val();
                const phone = $('#txtPhone').val();
                const address = $('#txtAddress').val();
                const city = $('#txtCity').val();

                const Supplier = {
                     SupplierId: idSupplier,
                    'Country': country,
                    'ContactName': contactName,
                    'CompanyName': company,
                    'Phone': phone,
                    'Address': address,
                    'City': city
                };

                if(idSupplier == 0)
                {
                    addSupplier(Supplier);
                }
                else
                {
                    confirmEditSupplier(Supplier);
                }

            }
        }


        //Funcion para poner campos obligatorios
        function validateForm(){


             if($('#txtCountry').val() == ''){
                $('#txtCountry').focus()
                toastMessage("warning",'El Pais es obligatorio')
                return false;
            }

             if($('#txtCompany').val() == ''){
                $('#txtCompany').focus()
                toastMessage("warning",'La Empresa es obligatoria')
                return false;
            }

             if($('#txtContactName').val() == ''){
                $('#txtContactName').focus()
                toastMessage("warning",'El Responsable es obligatorio')
                return false;
            }

             if($('#txtPhone').val() == ''){
                $('#txtPhone').focus()
                toastMessage("warning",'El Telofono es obligatorio')
                return false;
            }

               if($('#txtAddress').val() == ''){
                $('#txtAddress').focus()
                toastMessage("warning",'El Dirrecion es obligatorio')
                return false;
            }

               if($('#txtCity').val() == ''){
                $('#txtCity').focus()
                toastMessage("warning",'La Ciudad es obligatorio')
                return false;
            }


            return true;
        }

        //funcion para enviar los datos y agregarlos
        function addSupplier(Supplier){
             $.ajax({
                url: '@Url.Action("AddSupplier", "Supplier")', // cambia esta ruta por la real
                method: 'POST',
                //data son los parametros que vamos a enviar
                data:Supplier,
                DataTable: 'json',
                success: function(result){
                    console.log(result);
                    toastMessage('sucess', 'Registro creado exitosamente')
                    //clearFormSupplier();
                    getAllSupplier();

                },
                error: function (error) {
                    console.error(error);
                    alertError('Ha ocurrido un error, por favor vuelve a intentarlo');
                }
            });
        }

        //funcion para mostrar la informacion del registro a editar
        function editSupplier(id){
            idSupplier = id;
            //find se usa para filtrar
            const Supplier = listSupplier.find(x=> x.supplierId == idSupplier)


           
            $('#txtCountry').val(Supplier.country);
            $('#txtCompany').val(Supplier.companyName);
            $('#txtContactName').val(Supplier.contactName);
            $('#txtPhone').val(Supplier.phone);
            $('#txtAddress').val(Supplier.address);
            $('#txtCity').val(Supplier.city);

            openModal(true);
            console.log(idSupplier);

            console.log(Supplier);
        }

        //funcion para enviar la informacion actualizada
         function confirmEditSupplier(Supplier){

             console.log(idSupplier);
             console.log(Supplier);
             $.ajax({
                url: '@Url.Action("updateSupplier", "Supplier")', // cambia esta ruta por la real
                method: 'PUT',
                //data son los parametros que vamos a enviar
                data:Supplier,
                DataTable: 'json',
                success: function(result){
                    console.log(result);
                    toastMessage('sucess', 'Registro Editado exitosamente')
                    clearFormSupplier();
                    getAllSupplier();
                },
                error: function (error) {
                    console.error(error);
                    alertError('Ha ocurrido un error, por favor vuelve a intentarlo');
                    
                }
            });
        }
    </script>
}